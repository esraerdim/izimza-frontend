{
  "name": "izimza-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "json-server db.json --port 3001 --middlewares ./api/middleware.cjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.vue --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{ts,vue,css,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "axios": "^1.15.2",
    "multer": "^2.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/vue3-vite": "^10.3.6",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.0.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-vue": "^10.6.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.1",
    "json-server": "^0.17.4",
    "lint-staged": "^15.2.10",
    "prettier": "^3.7.2",
    "storybook": "^10.3.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.46.5",
    "vite": "^8.0.10",
    "vitest": "^4.0.2",
    "vue-eslint-parser": "^10.3.0",
    "vue-tsc": "^3.2.7"
  }
}
